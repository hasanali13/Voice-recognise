<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Origin Softwares</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Voice_recognise.styles.css" asp-append-version="true" />
    <style>
        body { background-color: #f4f6fb; }

        .navbar-brand-company {
            font-size: 1.3rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            color: #fff !important;
        }
        .navbar-brand-company span {
            background: linear-gradient(90deg, #00c6ff, #ffffff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .os-navbar {
            background: linear-gradient(90deg, #0d1b2a 0%, #1b3a5c 100%);
            box-shadow: 0 2px 8px rgba(0,0,0,0.18);
        }
        .os-navbar .nav-link { color: #cde4ff !important; font-weight: 500; }
        .os-navbar .nav-link:hover { color: #fff !important; }

        footer { background: #0d1b2a; color: #8aaccc; }
        footer a { color: #7fc6ff; }
        .os-footer-brand { font-weight: 700; color: #fff; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm os-navbar mb-0">
            <div class="container-fluid">
                <a class="navbar-brand navbar-brand-company" asp-area="" asp-controller="Home" asp-action="Index">
                    &#127908; <span>Origin Softwares</span>
                </a>
                <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Details" asp-action="Index">Records</a>
                        </li>
                    </ul>
                    <span class="badge bg-success ms-2 px-3 py-2" style="font-size:.85rem;">&#128994; Voice Enabled</span>
                </div>
            </div>
        </nav>
        <div style="height:4px;background:linear-gradient(90deg,#00c6ff,#0072ff,#00c6ff);"></div>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top py-3 mt-4">
        <div class="container d-flex justify-content-between align-items-center">
            <span>&copy; 2026 &nbsp;<span class="os-footer-brand">Origin Softwares</span> &mdash; Voice Recognition System</span>
            <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
